<?php 

declare(strict_types=1);

use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;
use Hyva\NetresearchShippingUi\Magewire\ParcelPackstationModal;
use Hyva\Theme\ViewModel\HyvaCsp;
use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;

/** @var Escaper $escaper */
/** @var Template $block */
/** @var ParcelPackstationModal $magewire */
/** @var Hyva\Theme\ViewModel\HyvaCsp $hyvaCsp */
/** @var ViewModelRegistry $viewModels */

/** @var HeroiconsOutline $heroIcons */
$heroicons = $viewModels->require(HeroiconsOutline::class);
?>
<script> 
    function mapdata() {
        return {
            map: null,           
            layers: {
                postoffice: null,
                locker: null,
                servicepoint: null,
            },
            visibility: {
                postoffice: true,
                locker: true,
                servicepoint: true,
            },
            address: {
                countryCode: '',
                city: '',
                postalCode: '',
                street: ''
            },
            showParcelShops: false,
            mapboxApiToken: '',
            mapTileUrl: '',
            mapAttribution: '',
            locationSearchUrl: '',
            currentDetailIndex: null,
            selectedLocation: null,
            isLoading: false,
            loadfiles: false,
            initialAddress: {},
            locations: [],
            finderErrorMessage: '',
            finderNoticeMessage: '',
            showMap: true,
            popupDelegationBound: false,
            mapInitScheduled: false,
            init() {
                try {
                    const parsed = JSON.parse(this.$el.dataset.shippingAddress);
                    this.address = {
                        countryCode: parsed.countryCode || 'DE',
                        city: parsed.city || '',
                        postalCode: parsed.postalCode || '',
                        street: parsed.street || ''
                    };
                } catch (e) {
                    console.warn('Invalid address JSON in data attribute', e);
                }
                this.mapboxApiToken = this.$el.dataset.mapboxToken || '';
                this.mapTileUrl = this.$el.dataset.mapTileUrl || '';
                this.mapAttribution = this.$el.dataset.mapAttribution || '';
                this.locationSearchUrl = this.$el.dataset.locationSearchUrl || '';

                if (!this.loadfiles) {
                    this.loadJsCss().then(() => {
                        this.loadfiles = true;
                        this.initMap();
                        this.bindPopupEventDelegation();

                        if (!this.mapTileUrl) {
                            return;
                        }

                        this.afterMapVisible(() => {
                            if (this.hasSearchableAddress()) {
                                this.fetchLocations();
                                return;
                            }

                            this.locations = [];
                            this.updateMarkers();
                            this.showFinderNotice(
                                '<?= $escaper->escapeJs(__('Please enter a postal code and city to search for DHL pickup locations.')) ?>'
                            );
                        });
                    });
                }
            },
            loadJsCss() {
                return new Promise(resolve => {
                    const script = document.createElement('script');
                    script.type = 'text/javascript';
                    script.src = '<?= $escaper->escapeUrl($block->getViewFileUrl("Netresearch_ShippingUi::lib/leaflet/leaflet.js")); ?>';
                    script.async = true;
                    script.onload = () => {
                        const link = document.createElement('link');
                        link.rel = 'stylesheet';
                        link.href = '<?= $escaper->escapeUrl($block->getViewFileUrl("Netresearch_ShippingUi::lib/leaflet/leaflet.css")); ?>';
                        link.onload = resolve;
                        document.head.appendChild(link);
                    };
                    document.head.appendChild(script);
                });
            },
            fetchLocations() {
                if (!this.locationSearchUrl) {
                    this.showFinderError(
                        '<?= $escaper->escapeJs(__('DHL pickup locations could not be loaded.')) ?>'
                    );
                    console.warn('DHL location finder: missing location search URL.');
                    return;
                }

                this.isLoading = true;
                //this.initialAddress = JSON.parse(JSON.stringify(this.address)); 
                this.initialAddress = { ...this.address };

                fetch(this.locationSearchUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        searchAddress: this.address
                    })
                })
                .then(async response => {
                    let payload = null;

                    try {
                        payload = await response.json();
                    } catch (e) {
                        payload = null;
                    }

                    if (!response.ok) {
                        const message = payload && payload.message
                            ? payload.message
                            : '<?= $escaper->escapeJs(__('DHL pickup locations could not be loaded.')) ?>';

                        if (response.status === 404 && payload && payload.message) {
                            return {
                                locations: [],
                                noticeMessage: message
                            };
                        }

                        throw new Error(message);
                    }

                    return payload;
                })
                .then(data => {
                    if (data && data.noticeMessage) {
                        this.locations = [];
                        this.updateMarkers();
                        this.showFinderNotice(data.noticeMessage);
                        return;
                    }

                    const locations = data && Array.isArray(data.locations) ? data.locations : data;

                    if (!Array.isArray(locations) || locations.length === 0) {
                        this.locations = [];
                        this.updateMarkers();
                        this.showFinderNotice(
                            '<?= $escaper->escapeJs(__('No DHL pickup locations were found for the specified address. Please try another address.')) ?>'
                        );
                        return;
                    }

                    this.clearFinderMessage();
                    this.showMap = true;
                    this.locations = locations;

                    this.afterMapVisible(() => {
                        this.updateMarkers();
                        this.updateMapViewport();
                        this.invalidateMapSize();
                    });
                })
                .catch(error => {
                    const message = error?.message || '<?= $escaper->escapeJs(__('DHL pickup locations could not be loaded.')) ?>';

                    this.locations = [];
                    this.updateMarkers();
                    this.showFinderError(message);
                    console.warn('DHL location finder:', message);
                })
                .finally(() => {
                    this.isLoading = false;
                });
            },
            searchLocations() {            
                if (!this.hasSearchableAddress()) {
                    this.locations = [];
                    this.updateMarkers();
                    this.showFinderNotice(
                        '<?= $escaper->escapeJs(__('Please enter a postal code and city to search for DHL pickup locations.')) ?>'
                    );
                    return;
                }

                if (JSON.stringify(this.address) === JSON.stringify(this.initialAddress)) {
                    this.showMap = true;
                    this.afterMapVisible(() => {
                        this.updateMarkers();
                        this.updateMapViewport();
                        this.invalidateMapSize();
                    });
                    return;
                }

                this.fetchLocations();
                Object.keys(this.visibility).forEach(key => this.visibility[key] = true);

                this.initialAddress = JSON.parse(JSON.stringify(this.address));
            },
            hasSearchableAddress() {
                return Boolean(
                    this.address
                    && this.address.countryCode
                    && this.address.postalCode
                    && this.address.city
                );
            },
            updateCountry(event) {
				this.address.countryCode = event?.target?.value || 'DE';
			},
            isCountry() {
                return this.address.countryCode === this.item.id;
            },
            setPostCode() {
                this.address.postalCode = this.$event.target.value;
            },
            setCity() {
                this.address.city = this.$event.target.value;
            },
            setStreet() {
                this.address.street = this.$event.target.value;
            },
            getMapContainer() {
                return this.$refs?.mapContainer || document.getElementById('dhl-location-finder-map') || null;
            },
            isMapContainerUsable(container) {
                return Boolean(
                    container
                    && container.isConnected
                    && container.offsetWidth > 0
                    && container.offsetHeight > 0
                );
            },
            initMap() {
                if (!this.showMap || !this.loadfiles || typeof L === 'undefined') {
                    return;
                }

                const container = this.getMapContainer();

                if (!this.isMapContainerUsable(container)) {
                    this.scheduleMapInit();
                    return;
                }

                if (this.map && this.map._container && this.map._container.isConnected) {
                    this.invalidateMapSize();
                    return;
                }

                this.destroyMap();

                this.map = L.map(container, {
					zoomAnimation: false,
					markerZoomAnimation: false,
					fadeAnimation: false
				});
                this.layers.postoffice = L.layerGroup();
                this.layers.locker = L.layerGroup();
                this.layers.servicepoint = L.layerGroup();

                if (!this.mapTileUrl) {
                    this.errorHandler('<?= $escaper->escapeJs(__('DHL pickup location map could not be loaded.')) ?>');
                    return;
                }

                L.tileLayer(this.mapTileUrl, {
                    maxZoom: 18,
                    tileSize: 512,
                    zoomOffset: -1,
                    id: 'mapbox/streets-v11',
                    accessToken: this.mapboxApiToken,
                    attribution: this.mapAttribution
                }).addTo(this.map);

                if (this.locations && this.locations.length > 0) {
                    this.setLocations(this.locations);
                }

                this.initLayerVisibility();
                this.invalidateMapSize();
            },
			destroyMap() {
				if (!this.map) {
					return;
				}

				const map = this.map;
				this.map = null;

				try {
					if (typeof map.stop === 'function') {
						map.stop();
					}

					if (typeof map.closePopup === 'function') {
						map.closePopup();
					}

					map.off();

					map.eachLayer(layer => {
						try {
							map.removeLayer(layer);
						} catch (e) {
							// ignore layer cleanup errors
						}
					});

					map.remove();
				} catch (e) {
					console.warn('DHL location finder: could not destroy Leaflet map', e);
				}

				this.layers = {
					postoffice: null,
					locker: null,
					servicepoint: null
				};
			},
            scheduleMapInit() {
                if (!this.showMap || this.mapInitScheduled) {
                    return;
                }

                this.mapInitScheduled = true;

                requestAnimationFrame(() => {
                    setTimeout(() => {
                        this.mapInitScheduled = false;
                        this.initMap();
                    }, 80);
                });
            },
            escapeHtml(value) {
                const div = document.createElement('div');
                div.textContent = value == null ? '' : String(value);
                return div.innerHTML;
            },
            setLocations(locations) {
                if (locations && locations.length > 0 && this.map) {
                    locations.forEach((location, index) => {
                        const latitude = Number(location.latitude);
                        const longitude = Number(location.longitude);

                        if (!Number.isFinite(latitude) || !Number.isFinite(longitude)) {
                            return;
                        }

                        const address = location.address || {};
                        const customIcon = L.icon({
                            iconUrl: location.icon,
                            iconSize: [55, 55],
                            iconAnchor: [25, 25],
                            popupAnchor: [1, -34],
                            className: location.shop_type,
                        });
                        
                        const countryCode = address.country_code || address.countryCode || address.country_id || '';
                        const postalCodeValue = address.postal_code || address.postalCode || address.postcode || '';
                        const parcelData = {
                          company: address.company || '',
                          displayName: location.display_name || location.displayName || '',
                          countryCode: countryCode,
                          postalCode: postalCodeValue,
                          number: location.shop_number || location.number || '',
                          city: address.city || '',
                          street: address.street || '',
                          type: location.shop_type || location.type || '',
                          id: location.shop_id || location.id || ''
                        };

                        const encodedParcelData = encodeURIComponent(JSON.stringify(parcelData)).replace(/'/g, '%27');
                        const displayName = this.escapeHtml(parcelData.displayName);
                        const company = this.escapeHtml(parcelData.company);
                        const street = this.escapeHtml(parcelData.street);
                        const postalCode = this.escapeHtml(parcelData.postalCode);
                        const city = this.escapeHtml(parcelData.city);

                        let marker = L.marker([latitude, longitude], { icon: customIcon });

                        if (location.shop_type === 'postoffice') {
                            this.layers.postoffice.addLayer(marker);
                        } else if (location.shop_type === 'locker') {
                            this.layers.locker.addLayer(marker);
                        } else if (location.shop_type === 'servicepoint') {
                            this.layers.servicepoint.addLayer(marker);
                        }

                        marker.bindPopup(`
                            <div class="flex flex-col">
                                <span class="font-bold pb-2">${displayName}</span>
                                <span class="font-bold">${company}</span>
                                <span>${street}</span>
                                <span>${postalCode} ${city}</span>
                                <div class="flex flex-row gap-x-2 pt-2">
                                    <button type="button" class="auto btn btn-primary"
                                            data-dhl-parcel-select="1"
                                            data-parcel='${encodedParcelData}'>
                                        <?= $escaper->escapeHtml(__('Select')) ?>
                                    </button>
                                    <button type="button"
                                            class="text-base"
                                            data-dhl-parcel-detail="1"
                                            data-index="${index}">
                                        <?= /* @noEscape */ $heroicons->informationCircleHtml('information-circle', 20, 20) ?>
                                    </button>
                                </div>
                            </div>
                        `);
                    });
                }
            },
            updateMarkers() {
                if (!this.map || !this.map._container || !this.map._container.isConnected) {
                    return;
                }

                if (this.layers) {
                    Object.values(this.layers).forEach(layerGroup => {
                        if (layerGroup) {
                            layerGroup.clearLayers();
                        }
                    });
                }

                this.setLocations(this.locations);
            },                
            showFinderNotice(message) {
				this.finderNoticeMessage = message || '';
				this.finderErrorMessage = '';
				this.locations = [];
				this.updateMarkers();
				this.showMap = false;
			},

			showFinderError(message) {
				this.finderErrorMessage = message || '';
				this.finderNoticeMessage = '';
				this.locations = [];
				this.updateMarkers();
				this.showMap = false;
			},
            clearFinderMessage() {
                this.finderNoticeMessage = '';
                this.finderErrorMessage = '';
            },
            afterMapVisible(callback) {
                this.showMap = true;

                requestAnimationFrame(() => {
                    setTimeout(() => {
                        this.initMap();

                        if (this.map) {
                            this.invalidateMapSize();
                        }

                        if (typeof callback === 'function') {
                            callback();
                        }
                    }, 80);
                });
            },
            invalidateMapSize() {
                if (!this.map) {
                    return;
                }

                const container = this.map._container || this.getMapContainer();
                if (!this.isMapContainerUsable(container)) {
                    return;
                }

                requestAnimationFrame(() => {
                    const currentContainer = this.map?._container || this.getMapContainer();
                    if (!this.map || !this.isMapContainerUsable(currentContainer)) {
                        return;
                    }

                    this.map.invalidateSize();

                    setTimeout(() => {
                        const delayedContainer = this.map?._container || this.getMapContainer();
                        if (this.map && this.isMapContainerUsable(delayedContainer)) {
                            this.map.invalidateSize();
                        }
                    }, 100);
                });
            },
            getValidLocationLatLngs(locations) {
                return (Array.isArray(locations) ? locations : [])
                    .map(location => [Number(location.latitude), Number(location.longitude)])
                    .filter(latLng => Number.isFinite(latLng[0]) && Number.isFinite(latLng[1]));
            },
            updateMapViewport() {
                if (!this.map || !Array.isArray(this.locations) || this.locations.length === 0) {
                    return;
                }

                const latLngs = this.getValidLocationLatLngs(this.locations);

                if (latLngs.length === 0) {
                    return;
                }

                if (latLngs.length === 1) {
                    this.map.setView(latLngs[0], 15);
                    return;
                }

                const bounds = L.latLngBounds(latLngs);
                this.map.fitBounds(bounds, {
                    padding: [40, 40],
                    maxZoom: 15
                });
            },
            setParcelShops(dataToSend) {
                Magewire.emitTo('checkout.shipping.method.dhlpaket_bestway_parcel_packstation', 'parcel_packstation_saved', {
                    'deliveryLocation': {
                        type: dataToSend.type,
                        id: dataToSend.id,
                        number: dataToSend.number,
                        displayName: dataToSend.displayName,
                        company: dataToSend.company,
                        countryCode: dataToSend.countryCode,
                        postalCode: dataToSend.postalCode,
                        city: dataToSend.city,
                        street: dataToSend.street
                    }
                });
                dispatchMessages([
                    {
                        type: "success",
                        text: "The address has been successfully added"
                    }
                ], 3000);
            },
            initLayerVisibility() {
                if (!this.map || !this.layers.postoffice || !this.layers.locker || !this.layers.servicepoint) {
                    return;
                }

                if (this.visibility.postoffice) {
                    this.map.addLayer(this.layers.postoffice);
                } else {
                    this.map.removeLayer(this.layers.postoffice);
                }
                if (this.visibility.locker) {
                    this.map.addLayer(this.layers.locker);
                } else {
                    this.map.removeLayer(this.layers.locker);
                }
                if (this.visibility.servicepoint) {
                    this.map.addLayer(this.layers.servicepoint);
                } else {
                    this.map.removeLayer(this.layers.servicepoint);
                }
            },
            onLayerToggle(event) {
                const layer = event.target.dataset.layerType;
                const isChecked = event.target.checked;
                this.visibility[layer] = isChecked;
                this.toggleLayer(layer);
            },
            toggleLayer(layerType) {
				if (!this.map || !this.layers?.[layerType]) {
					return;
				}

				const method = this.visibility[layerType] ? 'addLayer' : 'removeLayer';
				this.map[method](this.layers[layerType]);
				this.centerToNextLocation();
			},
            centerToNextLocation() {
				if (!this.map || !Array.isArray(this.locations)) {
					return;
				}

				const visible = this.locations.filter(loc => this.visibility[loc.shop_type]);
				const latLngs = this.getValidLocationLatLngs(visible);

				if (latLngs.length === 0) {
					return;
				}

				this.map.fitBounds(L.latLngBounds(latLngs), { maxZoom: 15 });
			},
            onCloseParcelShopDetail() {
                this.showParcelShops = false;
            },
            bindPopupEventDelegation() {
                if (this.popupDelegationBound) {
                    return;
                }

                this.popupDelegationBound = true;

                const root = this.$el || document;
                root.addEventListener('click', event => {
                    const target = event.target instanceof Element ? event.target : null;
                    if (!target) {
                        return;
                    }

                    const selectButton = target.closest('[data-dhl-parcel-select]');
                    if (selectButton) {
                        event.preventDefault();
                        this.handleParcelSelectButton(selectButton);
                        return;
                    }

                    const detailButton = target.closest('[data-dhl-parcel-detail]');
                    if (detailButton) {
                        event.preventDefault();
                        this.handleParcelDetailButton(detailButton);
                    }
                });
            },
            handleParcelDetailButton(button) {
                const index = Number(button?.dataset?.index);
                if (!Number.isInteger(index)) {
                    return;
                }

                this.showParcelShopDetail(index);
            },
            onParcelShopDetailClick(event) {
                this.handleParcelDetailButton(event.currentTarget);
            },
            hasOpeningHours() {
                return Array.isArray(this.selectedLocation?.opening_hours) && this.selectedLocation.opening_hours.length > 0;
            },
            hasServices() {
                return Array.isArray(this.selectedLocation?.services) && this.selectedLocation.services.length > 0;
            },
			showParcelShopDetail(index) {
				if (!this.map || !Array.isArray(this.locations) || !this.locations[index]) {
					return;
				}

				const location = this.locations[index];
				const latitude = Number(location.latitude);
				const longitude = Number(location.longitude);

				if (!Number.isFinite(latitude) || !Number.isFinite(longitude)) {
					return;
				}

				if (this.currentDetailIndex === index) {
					this.showParcelShops = !this.showParcelShops;
					return;
				}

				this.currentDetailIndex = index;
				this.selectedLocation = location;
				this.showParcelShops = true;

				if (this.map && this.map._container && this.map._container.isConnected) {
					this.map.setView([latitude, longitude]);
				}
			},
            handleParcelSelectButton(button) {
                const raw = button?.dataset?.parcel;
                if (!raw) {
                    return;
                }

                try {
                    const decoded = decodeURIComponent(raw);
                    const data = JSON.parse(decoded);
                    this.setParcelShops(data);
                } catch (e) {
                    this.errorHandler('Invalid parcel data: ' + e.message);
                }
            },
            onSelectParcelShop(event) {
                this.handleParcelSelectButton(event.currentTarget);
            },
            errorHandler(message) {
                this.showFinderError(message);
                console.warn('DHL location finder:', message);
            }
        }
    };
    function validateDhlPostnumber() {
        return {
            
        }
    };
    window.addEventListener('alpine:init', () => {
        Alpine.data('mapdata', mapdata);                          
    }, { once: true });
                
    window.addEventListener('checkout:init:evaluation', event => {
        hyvaCheckout.evaluation.registerValidator('validateDhlPostnumber', (element, component) => {
            const dl = component?.data?.deliveryLocation || {};
            const type = String(dl.type || '').toLowerCase();
            const isLocker = type === 'locker';

            const input = document.querySelector('[name="dhl_postnumber"], #dhl-postnumber');
            const val = (input?.value ?? dl.customerPostnumber ?? '').toString().trim();
            const isValid = /^\d{6,10}$/.test(val);

            if ((isLocker && val === '') || (val !== '' && !isValid) ) {
                if (window.Livewire) {
                    window.Livewire.emit('dhlPostnumberUpdated', val);
                }
                hyvaCheckout.messenger.dispatch(
                    'shipping:method',
                    '<?= $escaper->escapeJs(__('Unable to save shipping information. Please check input data.')) ?>',
                    'warning'
                );
                return false;
            }
            return true;
        });
    });
    window.addEventListener('checkout:step:loaded', function(event) {
        var quoteData = window.checkoutConfig && window.checkoutConfig.quoteData ? window.checkoutConfig.quoteData : {};
        if (
            quoteData.dhl_packstation_id ||
            quoteData.dhl_postfiliale_id ||
            (quoteData.dhl_services && quoteData.dhl_services.length > 0)
        ) {
            if (window.Livewire) {
                window.Livewire.emit('refreshState');
            }
            if (typeof $wire !== 'undefined' && $wire.refreshState) {
                $wire.refreshState();
            }
        }
    }, { once: true });
</script>
