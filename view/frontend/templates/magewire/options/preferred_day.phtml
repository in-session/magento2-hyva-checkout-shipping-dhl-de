<?php
declare(strict_types=1);

use Dhl\Paket\Model\ShippingSettings\ShippingOption\Codes as DhlCodes;
use Hyva\ShippingDhlDe\ViewModel\Tooltip;
use Hyva\Checkout\ViewModel\Checkout\Formatter as FormatterViewModel;

/** @var \Hyva\ShippingDhlDe\Magewire\DeliveryOptions $magewire */
$magewire = $block->getData('dhl_delivery_options');
if (!$magewire instanceof \Hyva\ShippingDhlDe\Magewire\DeliveryOptions) {
    return;
}
$viewModels = $block->getData('dhl_view_models') ?? ($viewModels ?? null);
if (!$viewModels instanceof \Hyva\Theme\Model\ViewModelRegistry) {
    return;
}
$escaper = $block->getData('dhl_escaper') ?? ($escaper ?? null);
if (!$escaper instanceof \Magento\Framework\Escaper) {
    return;
}
$tooltip = $viewModels->require(Tooltip::class);
$formatterViewModel = $viewModels->require(FormatterViewModel::class);
$code = DhlCodes::SERVICE_OPTION_PREFERRED_DAY;
if ($magewire->isOptionHidden($code)) { return; }
$disabled = $magewire->isOptionDisabled($code);
$feenote = str_replace('$1', $formatterViewModel->currency($magewire->preferredDayFee), __('This service will incur additional shipping costs of $1 including VAT.')->render());
$feeNoteId = 'preferred-day-fee-note';
$inputId = 'preferred_day';
$hasAvailableDays = $magewire->availableDays !== [];
$selectedPreferredDay = trim((string)($magewire->preferredDay ?? ''));
?>
<fieldset class="p-4 bg-white rounded-lg mt-0">
    <div class="flex flex-row items-start"><legend class="text-slate-800 text-base font-medium mb-0"><?= $escaper->escapeHtml(__('Delivery Day: Delivery on your preferred day')) ?></legend><?= $tooltip->render(__('Choose one of the displayed days for your parcel delivery. Other days are not possible due to delivery processes.')) ?></div>
    <?php if ($magewire->preferredDayFee > 0): ?><p class="text-sm" id="<?= $escaper->escapeHtmlAttr($feeNoteId) ?>"><?= $escaper->escapeHtml($feenote); ?></p><?php endif; ?>
    <div class="mt-3">
        <label for="<?= $escaper->escapeHtmlAttr($inputId) ?>" class="sr-only"><?= $escaper->escapeHtml(__('Delivery Day')) ?></label>
        <select id="<?= $escaper->escapeHtmlAttr($inputId) ?>" name="preferred_day" class="block w-full form-select grow renderer-select<?= ($disabled || !$hasAvailableDays) ? ' opacity-50 pointer-events-none' : '' ?>" data-dhl-preferred-day-select data-magewire-target="checkout.shipping.method.dhlpaket_bestway" <?= ($disabled || !$hasAvailableDays) ? 'disabled' : '' ?> <?= $magewire->preferredDayFee > 0 ? 'aria-describedby="' . $escaper->escapeHtmlAttr($feeNoteId) . '"' : '' ?>>
            <option value=""<?= $selectedPreferredDay === '' ? ' selected' : '' ?>><?= $escaper->escapeHtml(__('Please select a delivery day')) ?></option>
            <?php foreach ($magewire->availableDays as $availableDay): ?>
                <?php
                $availableDayValue = trim((string) ($availableDay['value'] ?? ''));
                $availableDayLabel = (string) ($availableDay['label'] ?? $availableDayValue);
                ?>
                <option value="<?= $escaper->escapeHtmlAttr($availableDayValue) ?>"<?= $selectedPreferredDay !== '' && $selectedPreferredDay === $availableDayValue ? ' selected' : '' ?>><?= $escaper->escapeHtml($availableDayLabel) ?></option>
            <?php endforeach; ?>
        </select>
        <?php if (!$hasAvailableDays): ?><p class="mt-2 text-sm text-slate-600"><?= $escaper->escapeHtml(__('No delivery days are currently available for this address.')) ?></p><?php endif; ?>
        <?php if (trim((string)$magewire->preferredDay) !== ''): ?><button type="button" class="btn btn-secondary mt-3" wire:click="clearPreferredDay"><?= $escaper->escapeHtml(__('Remove delivery day')) ?></button><?php endif; ?>
    </div>
</fieldset>
<script>
    if (!window.dhlPreferredDayCentralSelectDelegationBound) {
        window.dhlPreferredDayCentralSelectDelegationBound = true;

        document.addEventListener('change', function (event) {
            const target = event.target instanceof Element ? event.target : null;
            if (!target || !window.Magewire) {
                return;
            }

            const select = target.closest('[data-dhl-preferred-day-select]');
            if (!select) {
                return;
            }

            const magewireTarget = select.dataset.magewireTarget || 'checkout.shipping.method.dhlpaket_bestway';

            Magewire.emitTo(
                magewireTarget,
                'selectPreferredDay',
                select.value || ''
            );
        });
    }
</script>
<?php if (isset($hyvaCsp)): ?>
    <?php $hyvaCsp->registerInlineScript() ?>
<?php endif; ?>
