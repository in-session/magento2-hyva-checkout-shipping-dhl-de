<?php
declare(strict_types=1);

use Dhl\Paket\Model\ShippingSettings\ShippingOption\Codes as DhlCodes;
use Hyva\ShippingDhlDe\ViewModel\Tooltip;
use Hyva\Checkout\ViewModel\Checkout\Formatter as FormatterViewModel;

/** @var \Hyva\ShippingDhlDe\Magewire\DeliveryOptions $magewire */
$magewire = $block->getData('dhl_delivery_options');
if (!$magewire instanceof \Hyva\ShippingDhlDe\Magewire\DeliveryOptions) {
    return;
}
$viewModels = $block->getData('dhl_view_models') ?? ($viewModels ?? null);
if (!$viewModels instanceof \Hyva\Theme\Model\ViewModelRegistry) {
    return;
}
$escaper = $block->getData('dhl_escaper') ?? ($escaper ?? null);
if (!$escaper instanceof \Magento\Framework\Escaper) {
    return;
}
$tooltip = $viewModels->require(Tooltip::class);
$formatterViewModel = $viewModels->require(FormatterViewModel::class);
$code = DhlCodes::SERVICE_OPTION_NO_NEIGHBOR_DELIVERY;
if ($magewire->isOptionHidden($code)) { return; }
$disabled = $magewire->isOptionDisabled($code);
$feenote = str_replace('$1', $formatterViewModel->currency($magewire->noNeighborFee), __('This service will incur additional shipping costs of $1 including VAT.')->render());
$feeNoteId = 'no-neighbor-fee-note';
?>
<fieldset class="p-4 bg-white rounded-lg mt-0"><div class="flex items-start mb-2"><legend class="text-slate-800 text-base font-medium mb-0"><?= $escaper->escapeHtml(__('No Neighbor Delivery: Discreet Dispatch')) ?></legend><?= $tooltip->render(__('Exclude an alternative delivery to the neighbor if you are not available when the delivery is made.')) ?></div><label class="inline-flex items-start gap-x-4" for="noNeighbor"><input type="checkbox" id="noNeighbor" value="1" class="form-checkbox flex-none <?= $disabled ? ' opacity-50 pointer-events-none' : '' ?>" wire:click="toggleNoNeighbor" <?= (bool)$magewire->noNeighbor ? 'checked' : '' ?> <?= $disabled ? 'disabled' : '' ?> <?= $magewire->noNeighborFee > 0 ? 'aria-describedby="' . $escaper->escapeHtmlAttr($feeNoteId) . '"' : '' ?> /><span class="text-gray-700 hover:cursor-pointer"><?= $escaper->escapeHtml(__('Use No Neighbour Delivery Service')) ?></span></label><?php if ($magewire->noNeighborFee > 0): ?><p class="text-sm" id="<?= $escaper->escapeHtmlAttr($feeNoteId) ?>"><?= $escaper->escapeHtml($feenote); ?></p><?php endif; ?></fieldset>
