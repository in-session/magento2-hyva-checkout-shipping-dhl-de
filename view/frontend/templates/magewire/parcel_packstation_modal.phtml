<?php

declare(strict_types=1);

use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;
use Hyva\ShippingDhlDe\Magewire\ParcelPackstation;
use Hyva\ShippingDhlDe\ViewModel\LocationFinderConfig;
use Hyva\Theme\Model\ViewModelRegistry;
use Hyva\Theme\ViewModel\HeroiconsOutline;

/** @var Escaper $escaper */
/** @var Template $block */
/** @var ParcelPackstation $magewire */
/** @var ViewModelRegistry $viewModels */
/** @var LocationFinderConfig $locationFinderConfig */

/** @var HeroiconsOutline $heroIcons */
$heroicons = $viewModels->require(HeroiconsOutline::class);
$locationFinderConfig = $viewModels->require(LocationFinderConfig::class);

$componentShippingAddress = is_array($magewire->shippingAddress ?? null) ? $magewire->shippingAddress : [];
$street = $componentShippingAddress['street'] ?? '';

$shippingAddress = [
    'countryCode' => (string) ($componentShippingAddress['countryCode'] ?? 'DE'),
    'city'        => (string) ($componentShippingAddress['city'] ?? ''),
    'postalCode'  => (string) ($componentShippingAddress['postalCode'] ?? ''),
    'street'      => is_array($street) ? (string) ($street[0] ?? '') : trim((string) $street),
];
$shippingAddressJson = json_encode($shippingAddress, JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT);
?>
<div x-data="mapdata"
     class="w-full h-full relative"
     data-mapbox-token="<?= $escaper->escapeHtmlAttr($locationFinderConfig->getMapboxApiToken()) ?>"
     data-map-tile-url="<?= $escaper->escapeHtmlAttr($locationFinderConfig->getMapTileUrl()) ?>"
     data-map-attribution="<?= $escaper->escapeHtmlAttr($locationFinderConfig->getMapAttribution()) ?>"
     data-location-search-url="<?= $escaper->escapeUrl($locationFinderConfig->getLocationSearchUrl()) ?>"
     data-shipping-address="<?= $escaper->escapeHtmlAttr($shippingAddressJson ?: '{}') ?>">

    <button class="absolute right-0 top-0 p-6 cursor-pointer z-20"
            wire:click="closeModal"
            type="button"
            aria-label="<?= $escaper->escapeHtmlAttr(__('Close location finder')) ?>">
        <?= /* @noEscape */ $heroicons->xHtml('visibility.postoffice', 20, 20) ?>
    </button>

    <fieldset>
        <legend class="text-lg font-semibold mb-4">
            <?= $escaper->escapeHtml(__('Find DHL Pickup Location')) ?>
        </legend>
        <div class="grid grid-cols-12 gap-4">
            <div class="col-span-12 md:col-span-6 field-wrapper field-type-text">
                <label for="shipping-country" class="label text-sm text-slate-700">
                    <span><?= $escaper->escapeHtml(__('Country')) ?></span>
                </label>
                <select id="shipping-country"
                        class="form-select w-full"
                        name="country_finder"
                        @change="updateCountry($event)">
                    <option value="DE" selected>
                        <?= $escaper->escapeHtml(__('Germany')) ?>
                    </option>
                </select>
            </div>
            <div class="col-span-12 md:col-span-6 field-wrapper field-type-text">
                <label for="shipping-city" class="label text-sm text-slate-700">
                    <span><?= $escaper->escapeHtml(__('City')) ?></span>
                </label>
                <input type="text"
                       class="w-full form-input"
                       id="shipping-city"
                       :value="address.city"
                       @input="setCity"
                       placeholder="<?= $escaper->escapeHtmlAttr(__('City')) ?>" />
            </div>
            <div class="col-span-12 md:col-span-6 field-wrapper field-type-text">
                <label for="shipping-postalcode" class="label text-sm text-slate-700">
                    <span><?= $escaper->escapeHtml(__('Postal Code')) ?></span>
                </label>
                <input type="text"
                       class="w-full form-input"
                       id="shipping-postalcode"
                       :value="address.postalCode"
                       @input="setPostCode"
                       placeholder="<?= $escaper->escapeHtmlAttr(__('Postal Code')) ?>" />
            </div>
            <div class="col-span-12 md:col-span-6 field-wrapper field-type-text">
                <label for="shipping-street" class="label text-sm text-slate-700">
                    <span><?= $escaper->escapeHtml(__('Street')) ?></span>
                </label>
                <input type="text"
                       class="w-full form-input"
                       id="shipping-street"
                       :value="address.street"
                       @input="setStreet"
                       placeholder="<?= $escaper->escapeHtmlAttr(__('Street')) ?>" />
            </div>
            <div class="col-span-12">
                <button @click.prevent="searchLocations"
                        class="btn btn-primary text-sm mr-auto">
                    <span><?= $escaper->escapeHtml(__('Search')) ?></span>
                </button>
            </div>
        </div>
    </fieldset>

    <template x-if="finderErrorMessage">
        <div class="message error mt-4" x-text="finderErrorMessage"></div>
    </template>

    <template x-if="finderNoticeMessage">
        <div class="message notice mt-4" x-text="finderNoticeMessage"></div>
    </template>

    <div class="relative bg-white mt-6" x-show="showMap">
        <fieldset id="layer-control"
             class="absolute right-0 top-0 mr-2 mt-2 z-10 flex flex-col gap-y-2">
            <legend class="sr-only"><?= $escaper->escapeHtml(__('Filter location types')) ?></legend>
            <label for="postoffice-checkbox"
                   class="flex items-center gap-x-2 px-2 bg-white rounded-md">
                <input type="checkbox"
                       id="postoffice-checkbox"
                       :checked="visibility.postoffice"
                       data-layer-type="postoffice"
                       @change="onLayerToggle">
                <img src="<?= $block->escapeUrl($block->getViewFileUrl('Dhl_Paket::images/icon-postoffice.png')); ?>"
                     alt="<?= $escaper->escapeHtmlAttr(__('Postoffice')) ?>">
                <span class="sr-only"><?= $escaper->escapeHtml(__('Show Post offices')) ?></span>
            </label>
            <label for="locker-checkbox"
                   class="flex items-center gap-x-2 px-2 bg-white rounded-md">
                <input type="checkbox"
                       id="locker-checkbox"
                       :checked="visibility.locker"
                       data-layer-type="locker"
                       @change="onLayerToggle">
                <img src="<?= $block->escapeUrl($block->getViewFileUrl('Dhl_Paket::images/icon-packstation.png')); ?>"
                     alt="<?= $escaper->escapeHtmlAttr(__('Locker')) ?>">
                <span class="sr-only"><?= $escaper->escapeHtml(__('Show Lockers')) ?></span>
            </label>
            <label for="servicepoint-checkbox"
                   class="flex items-center gap-x-2 px-2 bg-white rounded-md">
                <input type="checkbox"
                       id="servicepoint-checkbox"
                       :checked="visibility.servicepoint"
                       data-layer-type="servicepoint"
                       @change="onLayerToggle">
                <img src="<?= $block->escapeUrl($block->getViewFileUrl('Dhl_Paket::images/icon-parcelshop.png')); ?>"
                     alt="<?= $escaper->escapeHtmlAttr(__('Servicepoint')) ?>">
                <span class="sr-only"><?= $escaper->escapeHtml(__('Show Service points')) ?></span>
            </label>
        </fieldset>

        <div class="relative w-full h-[50vh] md:w-[50vw] rounded-lg">
            <div class="w-full h-full z-0"
                 x-ref="mapContainer"
                 id="dhl-location-finder-map"></div>
            <template x-if="showParcelShops">
                <div class="absolute top-0 right-0 bottom-0 w-1/2 overflow-y-scroll shadow-2xl z-10 bg-white">
                    <div class="p-4 flex flex-col gap-6 z-1">
                        <button type="button"
                                @click="onCloseParcelShopDetail"
                                aria-label="<?= $escaper->escapeHtmlAttr(__('Close location details')) ?>"
                                class="absolute right-0 top-0 m-4">
                            <?= /* @noEscape */ $heroicons->xHtml('visibility.postoffice', 20, 20) ?>
                        </button>
                        <template x-if="selectedLocation">
                            <div>
                                <h3 class="font-bold mb-3" x-text="selectedLocation.display_name"></h3>
                                <h4 class="semi-bold"><?= $escaper->escapeHtml(__('Address') . ': ') ?></h4>
                                <p x-text="selectedLocation.address.company"></p>
                                <p x-text="selectedLocation.address.street"></p>
                                <p class="inline">
                                    <span x-text="selectedLocation.address.postal_code"></span>
                                    <span class="ml-1" x-text="selectedLocation.address.city"></span>
                                </p>
                            </div>
                        </template>
                        <template x-if="hasOpeningHours">
                            <div>
                                <h4 class="semi-bold"><?= $escaper->escapeHtml(__('Opening hours') . ': ') ?></h4>
                                <template x-for="opening_hour in selectedLocation.opening_hours"
                                          :key="opening_hour.day_of_week">
                                    <div class="flex gap-x-3">
                                        <span class="w-10" x-text="opening_hour.day_of_week"></span>
                                        <span>
                                            <template x-for="(time_frame, tfIndex) in opening_hour.time_frames" :key="tfIndex">
                                                <p class="flex flex-row gap-2">
                                                    <span x-text="time_frame.opens"></span>
                                                    <span>-</span>
                                                    <span x-text="time_frame.closes"></span>
                                                </p>
                                            </template>
                                        </span>
                                    </div>
                                </template>
                            </div>
                        </template>
                        <template x-if="hasServices">
                            <div>
                                <h4 class="semi-bold"><?= $escaper->escapeHtml(__('Services') . ': ') ?></h4>
                                <ul>
                                    <template x-for="service in selectedLocation.services" :key="service">
                                        <li>
                                            <span x-text="service"
                                                  class="inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-600 ring-1 ring-inset ring-gray-500/10"></span>
                                        </li>
                                    </template>
                                </ul>
                            </div>
                        </template>
                    </div>
                </div>
            </template>
            <div class="absolute top-0 w-full h-full bg-black/30 z-0"
                 @click="onCloseParcelShopDetail"
                 x-show="showParcelShops"></div>
        </div>
    </div>
</div>
